# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=videojuegos_db
DB_USER=root
DB_PASSWORD=rootpassword
MYSQL_ROOT_PASSWORD=rootpassword

# Local ports
BACKEND_PORT=3000
FRONTEND_PORT=8080

# AWS (used by CI/CD to push images & deploy) - fill with your values in GitHub Secrets or local env
AWS_REGION=us-east-1
ECR_REPOSITORY_FRONTEND=your-frontend-repo
ECR_REPOSITORY_BACKEND=your-backend-repo
ECS_CLUSTER=your-ecs-cluster
ECS_SERVICE=your-ecs-service
ECS_TASK_FAMILY=your-task-family
